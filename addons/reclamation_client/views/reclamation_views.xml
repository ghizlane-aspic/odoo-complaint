<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="reclamation_view_form" model="ir.ui.view">
        <field name="name">reclamation.client.form</field>
        <field name="model">reclamation.client</field>
        <field name="arch" type="xml">
            <form string="Customer Complaint">
                <header>
                    <button name="action_start" type="object" string="Start"
                            class="oe_highlight" invisible="state != 'new'"/>
                    <button name="action_resolve" type="object" string="Mark as Resolved"
                            class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_close" type="object" string="Close"
                            class="oe_highlight"
                            invisible="state not in ('in_progress', 'resolved')"/>
                    <button name="action_reset" type="object" string="Reset to New"
                            invisible="state == 'new'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Complaint Details">
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Dates">
                            <field name="date_open"/>
                            <field name="date_close"/>
                            <field name="delay_days"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the customer complaint..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="reclamation_view_list" model="ir.ui.view">
        <field name="name">reclamation.client.list</field>
        <field name="model">reclamation.client</field>
        <field name="arch" type="xml">
            <list string="Customer Complaints"
                  decoration-info="state == 'new'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="priority" widget="priority"/>
                <field name="date_open"/>
                <field name="date_close"/>
                <field name="delay_days"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'new'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'resolved'"
                       decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="reclamation_view_search" model="ir.ui.view">
        <field name="name">reclamation.client.search</field>
        <field name="model">reclamation.client</field>
        <field name="arch" type="xml">
            <search string="Search Complaints">
                <field name="name" string="Reference"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <separator/>
                <filter name="filter_new" string="New" domain="[('state', '=', 'new')]"/>
                <filter name="filter_in_progress" string="In Progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_resolved" string="Resolved"
                        domain="[('state', '=', 'resolved')]"/>
                <filter name="filter_closed" string="Closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter name="filter_priority_high" string="High Priority"
                        domain="[('priority', '=', 'high')]"/>
                <filter name="filter_priority_medium" string="Medium Priority"
                        domain="[('priority', '=', 'medium')]"/>
                <filter name="filter_priority_low" string="Low Priority"
                        domain="[('priority', '=', 'low')]"/>
                <separator/>
                <filter name="filter_my_complaints" string="My Complaints"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="group_state" string="Status"
                        context="{'group_by': 'state'}"/>
                <filter name="group_priority" string="Priority"
                        context="{'group_by': 'priority'}"/>
                <filter name="group_user" string="Assigned To"
                        context="{'group_by': 'user_id'}"/>
                <filter name="group_partner" string="Customer"
                        context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <record id="reclamation_action_all" model="ir.actions.act_window">
        <field name="name">All Complaints</field>
        <field name="path">reclamation-client</field>
        <field name="res_model">reclamation.client</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="reclamation_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first customer complaint
            </p>
            <p>
                Register, assign and track customer complaints through their full lifecycle.
            </p>
        </field>
    </record>

    <record id="reclamation_action_new" model="ir.actions.act_window">
        <field name="name">New Complaint</field>
        <field name="res_model">reclamation.client</field>
        <field name="view_mode">form,list</field>
        <field name="context">{'default_state': 'new'}</field>
    </record>

    <record id="reclamation_action_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">reclamation.client</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="reclamation_view_search"/>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>

</odoo>
