<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="reclamation_report_document">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang or 'en_US')"/>
            <div class="page">
                <div class="oe_structure"/>
                <h2 class="mt-2 mb-4">
                    Customer Complaint
                    <span t-field="doc.name"/>
                </h2>

                <div class="row mb-4">
                    <div class="col-6">
                        <strong>Customer:</strong>
                        <div t-field="doc.partner_id"
                             t-options='{"widget": "contact", "fields": ["name", "address", "phone", "email"], "no_marker": true}'/>
                    </div>
                    <div class="col-6">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td><strong>Opening Date</strong></td>
                                <td class="text-end"><span t-field="doc.date_open"/></td>
                            </tr>
                            <tr>
                                <td><strong>Closing Date</strong></td>
                                <td class="text-end">
                                    <span t-field="doc.date_close"/>
                                    <span t-if="not doc.date_close">-</span>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Resolution Delay</strong></td>
                                <td class="text-end"><span t-field="doc.delay_days"/> day(s)</td>
                            </tr>
                            <tr>
                                <td><strong>Priority</strong></td>
                                <td class="text-end"><span t-field="doc.priority"/></td>
                            </tr>
                            <tr>
                                <td><strong>Status</strong></td>
                                <td class="text-end"><span t-field="doc.state"/></td>
                            </tr>
                            <tr>
                                <td><strong>Assigned To</strong></td>
                                <td class="text-end"><span t-field="doc.user_id"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <h4 class="mb-2">Description</h4>
                <div class="border rounded p-3 mb-4" style="min-height: 80px;">
                    <span t-field="doc.description"/>
                    <span t-if="not doc.description" class="text-muted">No description provided.</span>
                </div>

                <div class="oe_structure"/>
            </div>
        </t>
    </template>

    <template id="reclamation_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="reclamation_client.reclamation_report_document"/>
            </t>
        </t>
    </template>
</odoo>
